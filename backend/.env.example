# Copie para .env e ajuste. NUNCA versione segredos reais.
SECRET_KEY=troque-por-um-segredo-forte-aleatorio
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MIN=30

# SQLite (dev) ou Postgres (prod), ex.:
# DATABASE_URL=postgresql+psycopg://user:senha@localhost:5432/saas_juridico
DATABASE_URL=sqlite:///./backend_app.db

# IA via Claude (opcional). Sem a chave, o endpoint /ia/peticao usa template local.
# ANTHROPIC_API_KEY=sk-ant-...
# Padrão claude-opus-4-7; para baratear use claude-haiku-4-5 ou claude-sonnet-4-6.
# CLAUDE_MODEL=claude-opus-4-7
